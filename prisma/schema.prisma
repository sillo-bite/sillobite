// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int      @id @default(autoincrement())
  email               String   @unique
  name                String
  phoneNumber         String?  @map("phone_number")
  role                UserRole   // "student", "staff", "employee", or "guest"
  
  // For students
  registerNumber      String?  @unique @map("register_number")
  college             String?
  department          String?
  joiningYear         Int?     @map("joining_year")
  passingOutYear      Int?     @map("passing_out_year")
  currentStudyYear    Int?     @map("current_study_year")
  isPassed            Boolean? @default(false) @map("is_passed")
  
  // For staff
  staffId             String?  @unique @map("staff_id")
  
  // For organization guest users
  organizationId      String?  @map("organization_id")
  
  // User selected location (for filtering canteens, menu, etc.)
  selectedLocationType String?  @map("selected_location_type") // "college", "organization", or "restaurant"
  selectedLocationId   String?  @map("selected_location_id") // ID of the selected college/organization/restaurant
  
  // Profile completion status
  isProfileComplete   Boolean? @default(false) @map("is_profile_complete")
  
  // Password for email/password authentication (optional - for Google OAuth users)
  passwordHash        String?  @map("password_hash")
  
  createdAt           DateTime @default(now()) @map("created_at")
  
  @@map("users")
}

model DeliveryPerson {
  id                  Int      @id @default(autoincrement())
  deliveryPersonId    String   @unique @map("delivery_person_id") // Unique identifier like DP001, DP002, etc.
  canteenId           String   @map("canteen_id") // Canteen ID from system settings
  name                String
  phoneNumber         String   @map("phone_number")
  email               String?
  employeeId          String?  @map("employee_id")
  address             String?
  city                String?
  state               String?
  pincode             String?
  dateOfBirth         DateTime? @map("date_of_birth")
  dateOfJoining       DateTime? @map("date_of_joining")
  vehicleNumber       String?  @map("vehicle_number")
  licenseNumber       String?  @map("license_number")
  emergencyContact    String?  @map("emergency_contact")
  emergencyContactName String? @map("emergency_contact_name")
  salary              Decimal? @db.Decimal(10, 2)
  isActive            Boolean  @default(true) @map("is_active")
  isAvailable         Boolean  @default(true) @map("is_available")
  totalOrderDelivered Int      @default(0) @map("total_order_delivered")
  notes               String?  @db.Text
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  
  @@index([canteenId, isActive])
  @@index([canteenId, isAvailable])
  @@index([deliveryPersonId])
  @@map("delivery_persons")
}

// Connection Code System
model ConnectionCode {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  code      String   @unique
  expiresAt DateTime @map("expires_at")
  isUsed    Boolean  @default(false) @map("is_used")
  createdAt DateTime @default(now()) @map("created_at")
  
  @@index([code])
  @@index([userId])
  @@index([expiresAt])
  @@map("connection_codes")
}

model ApiToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique @map("user_id")
  token     String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  
  @@index([token])
  @@map("api_tokens")
}

// Wallet System - Ledger-based approach
model Wallet {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique @map("user_id")
  balance   Decimal  @default(0) @db.Decimal(10, 2)
  currency  String   @default("INR")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  transactions WalletTransaction[]
  
  @@index([userId])
  @@map("wallets")
}

model WalletTransaction {
  id                String   @id @default(uuid())
  walletId          Int      @map("wallet_id")
  userId            Int      @map("user_id")
  type              TransactionType
  amount            Decimal  @db.Decimal(10, 2)
  balanceBefore     Decimal  @map("balance_before") @db.Decimal(10, 2)
  balanceAfter      Decimal  @map("balance_after") @db.Decimal(10, 2)
  description       String
  referenceType     String?  @map("reference_type") // "topup", "order", "refund", "cashback"
  referenceId       String?  @map("reference_id") // Order ID, Payment ID, etc.
  paymentMethod     String?  @map("payment_method") // "razorpay", "upi", etc.
  paymentId         String?  @map("payment_id") // Razorpay payment ID
  orderId           String?  @map("order_id") // Razorpay order ID
  status            TransactionStatus @default(PENDING)
  metadata          Json?    // Additional data
  createdAt         DateTime @default(now()) @map("created_at")
  
  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  
  @@index([walletId])
  @@index([userId])
  @@index([referenceId])
  @@index([paymentId])
  @@index([orderId])
  @@index([createdAt])
  @@map("wallet_transactions")
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
  REFUNDED
}

// All other models have been migrated to MongoDB
// Only User and DeliveryPerson models remain in PostgreSQL

enum UserRole {
  STUDENT         @map("student")
  STAFF           @map("staff")
  EMPLOYEE        @map("employee")
  GUEST           @map("guest")
  CONTRACTOR      @map("contractor")
  VISITOR         @map("visitor")
  ADMIN           @map("admin")
  SUPER_ADMIN     @map("super_admin")
  CANTEEN_OWNER   @map("canteen_owner")
  DELIVERY_PERSON @map("delivery_person")
}